{
    "$schema": "https://openapi.vercel.sh/vercel.json",
    "outputDirectory": ".",
    "functions": {
        "api/index.js": {
            "memory": 1024,
            "maxDuration": 30
        }
    },
    "rewrites": [
        { "source": "/api/(.*)", "destination": "/api" }
    ],
    "redirects": [
        {
            "source": "/(.*)",
            "has": [{ "type": "host", "value": "fineprint-ten.vercel.app" }],
            "destination": "https://fineprintdoc.com/$1",
            "permanent": true
        },
        {
            "source": "/(.*)",
            "has": [{ "type": "host", "value": "www.fineprintdoc.com" }],
            "destination": "https://fineprintdoc.com/$1",
            "permanent": true
        }
    ],
    "cleanUrls": true,
    "trailingSlash": false,
    "headers": [
        {
            "source": "/assets/(.*)",
            "headers": [
                { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
            ]
        },
        {
            "source": "/(.*\\.(?:svg|png|jpg|jpeg|ico|webp))",
            "headers": [
                { "key": "Cache-Control", "value": "public, max-age=86400" }
            ]
        }
    ]
}
